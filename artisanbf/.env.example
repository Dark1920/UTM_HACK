# ============================================
# ArtisanBF - Configuration des Variables d'Environnement
# ============================================
# Copiez ce fichier en .env.local et remplissez avec vos vraies valeurs

# ============================================
# SUPABASE (Obligatoire)
# ============================================
# Récupérez ces valeurs dans votre dashboard Supabase :
# Settings > API > Project URL & Project API Keys

NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=VOTRE_SERVICE_ROLE_KEY

# ============================================
# UPSTASH REDIS (Optionnel - pour le rate limiting)
# ============================================
# Récupérez ces valeurs dans votre dashboard Upstash :
# https://console.upstash.com/

UPSTASH_REDIS_REST_URL=https://VOTRE_REDIS_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=VOTRE_TOKEN

# ============================================
# GOOGLE MAPS (Optionnel - pour la géolocalisation)
# ============================================
# Récupérez cette clé dans Google Cloud Console :
# https://console.cloud.google.com/google/maps-apis/

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=VOTRE_GOOGLE_MAPS_KEY

# ============================================
# STRIPE (Optionnel - pour les paiements futurs)
# ============================================
# Récupérez ces valeurs dans votre dashboard Stripe :
# https://dashboard.stripe.com/apikeys

STRIPE_SECRET_KEY=sk_test_VOTRE_CLE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_VOTRE_CLE

# ============================================
# APPLICATION
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
